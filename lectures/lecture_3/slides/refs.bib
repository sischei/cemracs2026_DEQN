  Volume                   = {96},
  Abstract                 = {This paper studies an overlapping generations model with stochastic
	production and incomplete markets to assess whether the introduction
	of an unfunded social security system leads to a Pareto improvement.
	When returns to capital and wages are imperfectly correlated, a system
	that endows retired households with claims to labor income enhances
	the sharing of aggregate risk between generations. Our quantitative
	analysis shows that, abstracting from the capital crowding-out effect,
	the introduction of social security represents a Pareto-improving
	reform, even when the economy is dynamically efficient. However,
	the severity of the crowding-out effect in general equilibrium tends
	to overturn these gains. (JEL D58, D91, E62, H31, H55)},
}

@Article{RePEc:eee:dyncon:v:35:y:2011:i:2:p:175-177,
